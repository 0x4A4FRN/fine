# ─────────────────────────────────────────────────────────────
# Fine — Discord Moderation Bot
# Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Required ──────────────────────────────────────────────────

# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fine

# ── LLM ───────────────────────────────────────────────────────

# OpenAI-compatible API base URL
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   OpenRouter:   https://openrouter.ai/api/v1
#   LM Studio:    http://localhost:1234/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key(s). Single key or comma-separated for round-robin rotation.
# Example with 3 keys:
#   LLM_API_KEY=sk-key-aaa,sk-key-bbb,sk-key-ccc
LLM_API_KEY=

# Number of requests before rotating to the next API key.
# Also rotates immediately on HTTP 429 (rate limited).
# Only effective when multiple keys are configured.
LLM_KEY_ROTATE_EVERY=25

# Model name for chat completions
LLM_MODEL=gpt-4o-mini

# HTTP timeout for LLM requests (milliseconds)
LLM_TIMEOUT_MS=15000

# Max retries on transient errors (5xx, network). Exponential backoff: 1s, 2s, 4s
LLM_MAX_RETRIES=2

# Minimum LLM confidence to act on a response
LLM_CONFIDENCE_THRESHOLD=0.7

# ── Conversation ──────────────────────────────────────────────

# Conversation history window in minutes. Messages older than this
# are not included in LLM context.
CONVERSATION_WINDOW_MINUTES=30

# Max number of messages sent to the LLM as conversation history.
# Increase this for richer context, but watch your token budget.
# At ~20 req/min with 3 API keys, 30 is a safe choice.
CONVERSATION_HISTORY_MAX_MESSAGES=10

# Days before old conversation records are deleted from the DB
CONVERSATION_RETENTION_DAYS=30

# ── Confirmation ──────────────────────────────────────────────

# Seconds before a destructive-intent confirmation prompt expires
CONFIRM_WINDOW_SECONDS=60

# ── Cache ─────────────────────────────────────────────────────

# Minimum confidence for intent cache hits to bypass the LLM
CACHE_HIT_CONFIDENCE_MIN=0.7

# ── Audit ─────────────────────────────────────────────────────

# Days before old audit records are deleted from the DB
AUDIT_RETENTION_DAYS=90

# ── S3 / Snipe ────────────────────────────────────────────────

# S3-compatible endpoint URL (e.g. https://s3.amazonaws.com or an R2 endpoint)
# Required for snipe attachment archival. Snipe works for text-only messages
# without S3 configured.
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Days before sniped message snapshots are deleted from the DB
SNIPE_RETENTION_DAYS=7

# ── Logging ───────────────────────────────────────────────────

# Log level: debug, info, warn, error
LOG_LEVEL=info

# If set, also writes JSON logs to <dir>/fine.log in addition to stdout
# LOG_DIR=/var/log/fine

# ── Replies ───────────────────────────────────────────────────

# Path to the reply templates YAML file
REPLIES_PATH=internal/replies/replies.yaml
